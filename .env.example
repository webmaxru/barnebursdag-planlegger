# Kassal.app API key (https://kassal.app) – used server-side only for live price lookups.
# The app works without it; the "Vis priser" feature is disabled when empty.
KASSAL_API_KEY=

# Port the Node server listens on (Azure Container Apps target port).
PORT=8080

# Experimental "Handle på MENY" feature (shared meny.no cart). Hidden unless set to
# 1/true. See docs/meny-cart.md. Off by default. You can also preview it locally with
# the ?meny=1 URL query (no rebuild needed).
FEATURE_MENY_CART=

